{
  "name": "@uwdata/mosaic-core",
  "version": "0.29.1",
  "description": "Scalable and extensible linked data views.",
  "keywords": [
    "mosaic",
    "query",
    "duckdb",
    "data",
    "interface"
  ],
  "license": "BSD-3-Clause",
  "author": "Jeffrey Heer (https://idl.uw.edu)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./node-connector": {
      "types": "./dist/src/connectors/NodeConnector.d.ts",
      "default": "./dist/src/connectors/NodeConnector.js"
    }
  },
  "files": [
    "dist",
    "!dist/tsconfig.tsbuildinfo",
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/uwdata/mosaic.git"
  },
  "scripts": {
    "clean": "rimraf dist && mkdir dist",
    "lint": "eslint src test",
    "typecheck": "tsc -p test/tsconfig.json",
    "test": "vitest run",
    "prepublishOnly": "tsc --build"
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "1.33.1-dev57.0",
    "@uwdata/flechette": "^2.5.0",
    "@uwdata/mosaic-sql": "workspace:^"
  },
  "devDependencies": {
    "@uwdata/mosaic-duckdb": "workspace:^"
  },
  "peerDependencies": {
    "@uwdata/mosaic-duckdb": "workspace:^"
  },
  "peerDependenciesMeta": {
    "@uwdata/mosaic-duckdb": {
      "optional": true
    }
  }
}
