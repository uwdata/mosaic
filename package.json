{
  "private": true,
  "name": "mosaic",
  "description": "Scalable and extensible linked data views.",
  "license": "BSD-3-Clause",
  "author": "Jeffrey Heer (https://idl.uw.edu)",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/uwdata/mosaic.git"
  },
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:examples": "node bin/prepare-examples.js && uv run ruff format",
    "docs:preview": "vitepress preview docs",
    "docs:schema": "node bin/publish-schema.js && bin/push-schema.sh",
    "generate:python-api": "pnpm -F @uwdata/mosaic-spec run schema && node bin/generate-python-api.js && uv run ruff format packages/vgplot/vgplot-python/vgplot/_generated",
    "build": "tsc --build && lerna run build",
    "clean": "lerna run clean",
    "lint": "lerna run lint",
    "test": "tsc --build && lerna run schema && vitest run && pnpm -F mosaic-widget test",
    "server": "cd packages/server/duckdb-server && pnpm run dev",
    "server:rust": "cd packages/server/duckdb-server-rust && cargo run",
    "server:node": "nodemon packages/server/duckdb/bin/run-server.js",
    "dev": "vite"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@uwdata/mosaic-spec": "workspace:*",
    "globals": "^17.6.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^10.5.0",
    "jsdom": "^29.1.1",
    "lerna": "^9.0.7",
    "nodemon": "^3.1.14",
    "playwright": "^1.61.0",
    "rimraf": "^6.1.3",
    "timezone-mock": "^1.4.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "typescript-eslint": "^8.61.1",
    "vitepress": "~1.6.4",
    "vitest": "^4.1.9",
    "yaml": "^2.9.0"
  }
}
