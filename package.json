{
  "private": true,
  "name": "mosaic",
  "description": "Scalable and extensible linked data views.",
  "license": "BSD-3-Clause",
  "author": "Jeffrey Heer (https://idl.uw.edu)",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/uwdata/mosaic.git"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:examples": "node bin/prepare-examples.js",
    "docs:preview": "vitepress preview docs",
    "docs:schema": "node bin/publish-schema.js && bin/push-schema.sh",
    "build": "tsc --build && lerna run build",
    "clean": "lerna run clean",
    "lint": "lerna run lint",
    "test": "tsc --build && lerna run schema && vitest run && pnpm -F mosaic-widget test",
    "server": "cd packages/server/duckdb-server && pnpm run dev",
    "server:rust": "cd packages/server/duckdb-server-rust && cargo run",
    "server:node": "nodemon packages/server/duckdb/bin/run-server.js",
    "dev": "vite",
    "release": "pnpm run test && pnpm run lint && lerna publish && pnpm run release:python",
    "release:python": "pnpm run release:server && pnpm run release:widget",
    "release:server": "cd packages/server/duckdb-server && pnpm run release",
    "release:widget": "cd packages/vgplot/widget && pnpm run release"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "globals": "^17.4.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^10.2.0",
    "jsdom": "^29.0.1",
    "lerna": "^9.0.7",
    "nodemon": "^3.1.14",
    "rimraf": "^6.1.3",
    "timezone-mock": "^1.4.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "typescript-eslint": "^8.58.0",
    "vitepress": "1.6.4",
    "vitest": "^4.1.2",
    "yaml": "^2.8.3"
  }
}
